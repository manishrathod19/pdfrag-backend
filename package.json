{
  "name": "pdf-rag-backend",
  "version": "1.0.0",
  "description": "Local-only RAG backend for the PDF Assistant. Express + TypeScript, with @xenova/transformers, Qdrant and Ollama.",
  "main": "server.ts",
  "scripts": {
    "build": "tsc",
    "start": "npx ts-node src/server.ts",
    "dev": "npx ts-node src/server.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["rag", "pdf", "qdrant", "ollama", "transformers", "express"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@qdrant/js-client-rest": "^1.11.0",
    "@xenova/transformers": "^2.17.2",
    "chokidar": "^3.6.0",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "multer": "^1.4.5-lts.1",
    "ollama": "^0.5.9",
    "pdf-parse": "^1.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.10",
    "@types/pdf-parse": "^1.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.3"
  }
}
